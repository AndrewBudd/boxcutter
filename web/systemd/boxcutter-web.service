[Unit]
Description=Boxcutter Web UI (Next.js)
After=network.target boxcutter-orchestrator.service
Wants=boxcutter-orchestrator.service

[Service]
Type=simple
WorkingDirectory=/var/lib/boxcutter/web
ExecStart=/usr/bin/node /var/lib/boxcutter/web/node_modules/.bin/next start -p 3000
Environment=NODE_ENV=production
Environment=ORCHESTRATOR_API=http://localhost:8801
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
