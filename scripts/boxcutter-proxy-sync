#!/bin/bash
SLICER_API="http://127.0.0.1:8080"
TOKEN=$(cat /var/lib/slicer/auth/token)
CADDY_SITES="/etc/caddy/sites"
LAST_HASH=""

while true; do
  VMS=$(curl -s -H "Authorization: Bearer ${TOKEN}" "${SLICER_API}/nodes" 2>/dev/null)

  if [ -z "$VMS" ] || [ "$VMS" = "null" ]; then
    sleep 5
    continue
  fi

  GENERATED=""

  while IFS= read -r vm; do
    HOSTNAME=$(echo "$vm" | jq -r '.hostname')
    IP=$(echo "$vm" | jq -r '.ip')
    [ -z "$HOSTNAME" ] || [ "$HOSTNAME" = "null" ] && continue
    [ -z "$IP" ] || [ "$IP" = "null" ] && continue

    SERVICES=$(curl -s -X POST \
      -H "Authorization: Bearer ${TOKEN}" \
      "${SLICER_API}/vm/${HOSTNAME}/exec?cmd=cat&args=/home/dev/.services&stdout=true&uid=0&shell=" \
      2>/dev/null | grep '"stdout"' | head -1 | jq -r '.stdout // ""')

    [ -z "$SERVICES" ] && continue

    CADDY_BLOCK=""
    while IFS='=' read -r name port; do
      [[ "$name" =~ ^#.*$ ]] && continue
      [ -z "$name" ] || [ -z "$port" ] && continue
      CADDY_BLOCK+="${name}.${HOSTNAME}.vm.lan {
  tls internal
  reverse_proxy ${IP}:${port}
}

"
    done <<< "$SERVICES"

    if [ -n "$CADDY_BLOCK" ]; then
      {
        echo "# Auto-generated by boxcutter-proxy-sync — do not edit"
        echo "$CADDY_BLOCK"
      } > "${CADDY_SITES}/${HOSTNAME}.caddy"
      GENERATED="$GENERATED $HOSTNAME"
    fi
  done < <(echo "$VMS" | jq -c '.[]')

  # Remove stale configs
  for f in "${CADDY_SITES}"/*.caddy; do
    [ -f "$f" ] || continue
    fname=$(basename "$f" .caddy)
    echo "$GENERATED" | grep -qw "$fname" || rm -f "$f"
  done

  # Reload Caddy if changed
  CURRENT_HASH=$(find "${CADDY_SITES}" -name "*.caddy" -exec md5sum {} \; | sort | md5sum)
  if [ "$CURRENT_HASH" != "$LAST_HASH" ]; then
    systemctl reload caddy 2>/dev/null
    LAST_HASH="$CURRENT_HASH"
  fi

  sleep 5
done
