#!/bin/bash
# Polls running VMs for .services declarations and updates Caddy reverse proxy config.
# Replaces SlicerVM API polling with direct SSH into VMs.

BOXCUTTER_HOME="/var/lib/boxcutter"
VM_DIR="${BOXCUTTER_HOME}/vms"
SSH_KEY="${BOXCUTTER_HOME}/ssh/id_ed25519"
CADDY_SITES="/etc/caddy/sites"
LAST_HASH=""

while true; do
  GENERATED=""

  for vm_dir in "${VM_DIR}"/*/; do
    [ -f "${vm_dir}/vm.json" ] || continue
    [ -f "${vm_dir}/firecracker.pid" ] || continue

    pid=$(cat "${vm_dir}/firecracker.pid")
    kill -0 "$pid" 2>/dev/null || continue

    name=$(basename "$vm_dir")
    ip=$(jq -r '.ip' "${vm_dir}/vm.json")
    [ -z "$ip" ] || [ "$ip" = "null" ] && continue

    SERVICES=$(ssh -i "$SSH_KEY" \
      -o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null \
      -o ConnectTimeout=2 -o BatchMode=yes \
      "dev@${ip}" cat /home/dev/.services 2>/dev/null) || continue

    [ -z "$SERVICES" ] && continue

    CADDY_BLOCK=""
    while IFS='=' read -r svc_name port; do
      [[ "$svc_name" =~ ^#.*$ ]] && continue
      svc_name=$(echo "$svc_name" | tr -d ' ')
      port=$(echo "$port" | tr -d ' ')
      [ -z "$svc_name" ] || [ -z "$port" ] && continue
      CADDY_BLOCK+="${svc_name}.${name}.vm.lan {
  tls internal
  reverse_proxy ${ip}:${port}
}

"
    done <<< "$SERVICES"

    if [ -n "$CADDY_BLOCK" ]; then
      {
        echo "# Auto-generated by boxcutter-proxy-sync"
        echo "$CADDY_BLOCK"
      } > "${CADDY_SITES}/${name}.caddy"
      GENERATED="$GENERATED $name"
    fi
  done

  # Remove stale configs
  for f in "${CADDY_SITES}"/*.caddy; do
    [ -f "$f" ] || continue
    fname=$(basename "$f" .caddy)
    echo "$GENERATED" | grep -qw "$fname" || rm -f "$f"
  done

  # Reload Caddy if changed
  CURRENT_HASH=$(find "${CADDY_SITES}" -name "*.caddy" -exec md5sum {} \; 2>/dev/null | sort | md5sum)
  if [ "$CURRENT_HASH" != "$LAST_HASH" ]; then
    systemctl reload caddy 2>/dev/null || true
    LAST_HASH="$CURRENT_HASH"
  fi

  sleep 5
done
