#!/bin/bash
# boxcutter-ctl — Firecracker microVM lifecycle manager
# Replaces SlicerVM with direct Firecracker management.
set -eo pipefail

BOXCUTTER_HOME="/var/lib/boxcutter"
VM_DIR="${BOXCUTTER_HOME}/vms"
KERNEL="${BOXCUTTER_HOME}/kernel/vmlinux"
GOLDEN="${BOXCUTTER_HOME}/golden/rootfs.ext4"
BRIDGE="brvm0"
SUBNET="192.168.137"
SSH_KEY="${BOXCUTTER_HOME}/ssh/id_ed25519"

DEFAULT_VCPU=4
DEFAULT_RAM_MIB=8192
DEFAULT_DISK="50G"

usage() {
  cat <<EOF
boxcutter-ctl — Firecracker microVM manager

Commands:
  create <name> [--vcpu N] [--ram MiB] [--disk SIZE]
  start <name>
  stop <name>
  destroy <name>
  list
  shell <name>
  status
  golden build [SIZE]    Build golden rootfs image

Usage: boxcutter-ctl <command> [args]
EOF
}

# --- IP/MAC allocation ---

allocate_ip() {
  local max=1
  for d in "${VM_DIR}"/*/; do
    [ -f "${d}/vm.json" ] || continue
    local ip
    ip=$(jq -r '.ip' "${d}/vm.json" 2>/dev/null) || continue
    local idx=${ip##*.}
    [ "$idx" -gt "$max" ] 2>/dev/null && max=$idx
  done
  echo "${SUBNET}.$((max + 1))"
}

ip_to_mac() {
  printf "AA:FC:00:00:00:%02X" "${1##*.}"
}

# --- TAP device naming (max 15 chars) ---
tap_name() {
  local name=$1
  local tap="tap-${name}"
  if [ ${#tap} -le 15 ]; then
    echo "$tap"
  else
    # Truncate and add hash suffix for uniqueness
    local hash
    hash=$(echo -n "$name" | md5sum | cut -c1-4)
    echo "tap-${name:0:7}${hash}"
  fi
}

# --- Commands ---

cmd_create() {
  local name=$1; shift
  local vcpu=$DEFAULT_VCPU ram=$DEFAULT_RAM_MIB disk=$DEFAULT_DISK

  while [ $# -gt 0 ]; do
    case "$1" in
      --vcpu) vcpu=$2; shift 2 ;;
      --ram)  ram=$2; shift 2 ;;
      --disk) disk=$2; shift 2 ;;
      *) echo "Unknown option: $1"; exit 1 ;;
    esac
  done

  [ -z "$name" ] && { echo "Usage: boxcutter-ctl create <name> [options]"; exit 1; }
  [ -d "${VM_DIR}/${name}" ] && { echo "VM '${name}' already exists."; exit 1; }
  [ -f "$GOLDEN" ] || { echo "Golden image not found. Run: boxcutter-ctl golden build"; exit 1; }

  echo "Creating VM: ${name} (${vcpu} vCPU, $((ram / 1024))GB RAM, ${disk} disk)"

  mkdir -p "${VM_DIR}/${name}"

  local ip mac tap
  ip=$(allocate_ip)
  mac=$(ip_to_mac "$ip")
  tap=$(tap_name "$name")

  # Copy golden image (sparse/reflink)
  echo "  Copying golden image..."
  cp --reflink=auto --sparse=always "$GOLDEN" "${VM_DIR}/${name}/rootfs.ext4"

  # Resize if larger than golden
  local disk_bytes current_bytes
  disk_bytes=$(numfmt --from=iec "$disk" 2>/dev/null || echo 0)
  current_bytes=$(stat -c%s "${VM_DIR}/${name}/rootfs.ext4")
  if [ "$disk_bytes" -gt "$current_bytes" ] 2>/dev/null; then
    truncate -s "$disk" "${VM_DIR}/${name}/rootfs.ext4"
    e2fsck -f -y "${VM_DIR}/${name}/rootfs.ext4" >/dev/null 2>&1 || true
    resize2fs "${VM_DIR}/${name}/rootfs.ext4" >/dev/null 2>&1 || true
  fi

  # VM metadata
  cat > "${VM_DIR}/${name}/vm.json" <<EOF
{
  "name": "${name}",
  "vcpu": ${vcpu},
  "ram_mib": ${ram},
  "ip": "${ip}",
  "mac": "${mac}",
  "disk": "${disk}",
  "tap": "${tap}",
  "created": "$(date -Iseconds)"
}
EOF

  # Firecracker config
  cat > "${VM_DIR}/${name}/fc-config.json" <<EOF
{
  "boot-source": {
    "kernel_image_path": "${KERNEL}",
    "boot_args": "console=ttyS0 reboot=k panic=1 pci=off random.trust_cpu=on root=/dev/vda rw init=/sbin/init"
  },
  "drives": [
    {
      "drive_id": "rootfs",
      "path_on_host": "${VM_DIR}/${name}/rootfs.ext4",
      "is_root_device": true,
      "is_read_only": false
    }
  ],
  "network-interfaces": [
    {
      "iface_id": "eth0",
      "guest_mac": "${mac}",
      "host_dev_name": "${tap}"
    }
  ],
  "machine-config": {
    "vcpu_count": ${vcpu},
    "mem_size_mib": ${ram}
  },
  "entropy": {
    "rate_limiter": {
      "bandwidth": {
        "size": 1048576,
        "refill_time": 1000
      }
    }
  }
}
EOF

  # Inject any additional SSH keys added after golden image build
  if [ -f /etc/boxcutter/authorized_keys ]; then
    echo "  Injecting user SSH keys..."
    MOUNT_DIR=$(mktemp -d)
    mount -o loop "${VM_DIR}/${name}/rootfs.ext4" "$MOUNT_DIR"
    mkdir -p "${MOUNT_DIR}/home/dev/.ssh"
    # Merge: keep golden keys + add current trusted keys
    if [ -f "${MOUNT_DIR}/home/dev/.ssh/authorized_keys" ]; then
      # Append any keys not already present
      while IFS= read -r key; do
        grep -qF "$key" "${MOUNT_DIR}/home/dev/.ssh/authorized_keys" 2>/dev/null || \
          echo "$key" >> "${MOUNT_DIR}/home/dev/.ssh/authorized_keys"
      done < /etc/boxcutter/authorized_keys
    else
      cp /etc/boxcutter/authorized_keys "${MOUNT_DIR}/home/dev/.ssh/authorized_keys"
    fi
    chown -R 1000:1000 "${MOUNT_DIR}/home/dev/.ssh"
    chmod 700 "${MOUNT_DIR}/home/dev/.ssh"
    chmod 600 "${MOUNT_DIR}/home/dev/.ssh/authorized_keys"
    umount "$MOUNT_DIR"
    rmdir "$MOUNT_DIR"
  fi

  echo "  VM created: ${name} (IP: ${ip})"
  echo "  Start with: boxcutter-ctl start ${name}"
}

cmd_start() {
  local name=$1
  [ -z "$name" ] && { echo "Usage: boxcutter-ctl start <name>"; exit 1; }
  [ -d "${VM_DIR}/${name}" ] || { echo "VM '${name}' does not exist."; exit 1; }

  if [ -f "${VM_DIR}/${name}/firecracker.pid" ]; then
    local pid
    pid=$(cat "${VM_DIR}/${name}/firecracker.pid")
    kill -0 "$pid" 2>/dev/null && { echo "VM '${name}' is already running (PID ${pid})."; exit 1; }
  fi

  local ip mac tap
  ip=$(jq -r '.ip' "${VM_DIR}/${name}/vm.json")
  mac=$(jq -r '.mac' "${VM_DIR}/${name}/vm.json")
  tap=$(jq -r '.tap // empty' "${VM_DIR}/${name}/vm.json")
  [ -z "$tap" ] && tap=$(tap_name "$name")

  echo "Starting VM: ${name} (${ip})"

  # Create TAP device
  if ! ip link show "$tap" &>/dev/null; then
    ip tuntap add dev "$tap" mode tap
    ip link set "$tap" master "${BRIDGE}"
    ip link set "$tap" up
  fi

  # DHCP reservation
  mkdir -p /etc/boxcutter/dhcp-hosts
  echo "${mac},${ip},${name}" > "/etc/boxcutter/dhcp-hosts/${name}"
  # Signal dnsmasq to re-read
  kill -HUP "$(cat /run/dnsmasq/dnsmasq.pid 2>/dev/null)" 2>/dev/null || kill -HUP "$(pidof dnsmasq 2>/dev/null)" 2>/dev/null || true

  # Clean stale socket
  rm -f "${VM_DIR}/${name}/api.sock"

  # Launch Firecracker
  firecracker \
    --api-sock "${VM_DIR}/${name}/api.sock" \
    --config-file "${VM_DIR}/${name}/fc-config.json" \
    > "${VM_DIR}/${name}/firecracker.log" 2>&1 &

  echo $! > "${VM_DIR}/${name}/firecracker.pid"

  echo "  VM started (PID $(cat "${VM_DIR}/${name}/firecracker.pid"))"
  echo "  Shell: boxcutter-ctl shell ${name}"
}

cmd_stop() {
  local name=$1
  [ -z "$name" ] && { echo "Usage: boxcutter-ctl stop <name>"; exit 1; }
  [ -f "${VM_DIR}/${name}/firecracker.pid" ] || { echo "VM '${name}' is not running."; return 0; }

  local pid
  pid=$(cat "${VM_DIR}/${name}/firecracker.pid")

  echo "Stopping VM: ${name}"

  # Graceful shutdown via Firecracker API
  if [ -S "${VM_DIR}/${name}/api.sock" ]; then
    curl -s --unix-socket "${VM_DIR}/${name}/api.sock" \
      -X PUT http://localhost/actions \
      -H 'Content-Type: application/json' \
      -d '{"action_type":"SendCtrlAltDel"}' 2>/dev/null || true

    for _ in $(seq 1 10); do
      kill -0 "$pid" 2>/dev/null || break
      sleep 1
    done
  fi

  # Force kill if still running
  if kill -0 "$pid" 2>/dev/null; then
    kill -9 "$pid" 2>/dev/null || true
  fi

  # Cleanup
  local tap
  tap=$(jq -r '.tap // empty' "${VM_DIR}/${name}/vm.json" 2>/dev/null)
  [ -z "$tap" ] && tap=$(tap_name "$name")
  rm -f "${VM_DIR}/${name}/firecracker.pid" "${VM_DIR}/${name}/api.sock"
  ip link del "$tap" 2>/dev/null || true
  rm -f "/etc/boxcutter/dhcp-hosts/${name}"
  kill -HUP "$(cat /run/dnsmasq/dnsmasq.pid 2>/dev/null)" 2>/dev/null || kill -HUP "$(pidof dnsmasq 2>/dev/null)" 2>/dev/null || true

  echo "  Stopped."
}

cmd_destroy() {
  local name=$1
  [ -z "$name" ] && { echo "Usage: boxcutter-ctl destroy <name>"; exit 1; }
  [ -d "${VM_DIR}/${name}" ] || { echo "VM '${name}' does not exist."; exit 1; }

  # Stop if running
  if [ -f "${VM_DIR}/${name}/firecracker.pid" ]; then
    local pid
    pid=$(cat "${VM_DIR}/${name}/firecracker.pid")
    kill -0 "$pid" 2>/dev/null && cmd_stop "$name"
  fi

  rm -rf "${VM_DIR:?}/${name}"
  echo "VM '${name}' destroyed."
}

cmd_list() {
  printf "%-15s %-18s %-8s %-10s %-8s\n" "NAME" "IP" "VCPU" "RAM" "STATUS"
  for d in "${VM_DIR}"/*/; do
    [ -f "${d}/vm.json" ] || continue
    local name ip vcpu ram status
    name=$(basename "$d")
    ip=$(jq -r '.ip' "${d}/vm.json")
    vcpu=$(jq -r '.vcpu' "${d}/vm.json")
    ram=$(jq -r '.ram_mib' "${d}/vm.json")
    status="stopped"
    if [ -f "${d}/firecracker.pid" ]; then
      local pid
      pid=$(cat "${d}/firecracker.pid")
      kill -0 "$pid" 2>/dev/null && status="running"
    fi
    printf "%-15s %-18s %-8s %-10s %-8s\n" "$name" "$ip" "$vcpu" "$((ram/1024))GB" "$status"
  done
}

cmd_shell() {
  local name=$1
  [ -z "$name" ] && { echo "Usage: boxcutter-ctl shell <name>"; exit 1; }
  [ -d "${VM_DIR}/${name}" ] || { echo "VM '${name}' does not exist."; exit 1; }

  local ip
  ip=$(jq -r '.ip' "${VM_DIR}/${name}/vm.json")
  exec ssh -tt -i "$SSH_KEY" -o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null "dev@${ip}"
}

cmd_status() {
  local total_ram used_ram=0 vm_count=0 running=0
  total_ram=$(free -g | awk '/^Mem:/{print $2}')

  for d in "${VM_DIR}"/*/; do
    [ -f "${d}/vm.json" ] || continue
    vm_count=$((vm_count + 1))
    if [ -f "${d}/firecracker.pid" ]; then
      local pid
      pid=$(cat "${d}/firecracker.pid")
      if kill -0 "$pid" 2>/dev/null; then
        running=$((running + 1))
        local ram
        ram=$(jq -r '.ram_mib' "${d}/vm.json")
        used_ram=$((used_ram + ram / 1024))
      fi
    fi
  done

  echo "Host: $(hostname)"
  echo "VMs: ${running} running / ${vm_count} total"
  echo "RAM: ${used_ram}GB allocated / ${total_ram}GB total"
  echo "Headroom: $((total_ram - used_ram))GB"
}

# --- Main ---

case "${1:-help}" in
  create)  shift; cmd_create "$@" ;;
  start)   cmd_start "$2" ;;
  stop)    cmd_stop "$2" ;;
  destroy) cmd_destroy "$2" ;;
  list)    cmd_list ;;
  shell)   cmd_shell "$2" ;;
  status)  cmd_status ;;
  golden)
    case "$2" in
      build) exec "${BOXCUTTER_HOME}/golden/build.sh" "${3:-}" ;;
      provision)
        # Boot golden image as a temp VM, SSH in, run provision.sh
        echo "=== Provisioning golden image (Phase 2) ==="
        GOLDEN="${BOXCUTTER_HOME}/golden/rootfs.ext4"
        [ -f "$GOLDEN" ] || { echo "No golden base image. Run: boxcutter-ctl golden build"; exit 1; }

        # Create temp VM from golden image
        cmd_create _gprov --vcpu 8 --ram 16384
        cmd_start _gprov

        PROV_IP=$(jq -r '.ip' "${VM_DIR}/_gprov/vm.json")
        echo "Waiting for VM to boot..."
        for i in $(seq 1 60); do
          ssh -i "$SSH_KEY" -o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null \
            -o ConnectTimeout=2 -o BatchMode=yes "dev@${PROV_IP}" echo ready 2>/dev/null && break
          sleep 2
        done

        echo "Running provision script inside VM..."
        PROV_SCRIPT="${BOXCUTTER_HOME}/golden/provision.sh"
        [ -f "$PROV_SCRIPT" ] || PROV_SCRIPT="/mnt/boxcutter/golden/provision.sh"
        ssh -i "$SSH_KEY" -o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null \
          "dev@${PROV_IP}" "sudo bash -s" < "$PROV_SCRIPT"

        echo "Shutting down provision VM..."
        cmd_stop _gprov

        # Replace golden image with the provisioned one
        cp "${VM_DIR}/_gprov/rootfs.ext4" "$GOLDEN"
        cmd_destroy _gprov

        echo ""
        echo "=== Golden image provisioned ==="
        echo "Path: ${GOLDEN}"
        du -h "$GOLDEN"
        ;;
      *) echo "Usage: boxcutter-ctl golden {build|provision}" ;;
    esac
    ;;
  help|*) usage ;;
esac
