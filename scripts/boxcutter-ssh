#!/bin/bash
# Boxcutter SSH control interface — ForceCommand dispatch.
# Translates SSH commands to boxcutter-ctl calls.

read -r -a ARGS <<< "${SSH_ORIGINAL_COMMAND:-help}"
ACTION="${ARGS[0]}"
TARGET="${ARGS[1]}"

CTL="sudo /usr/local/bin/boxcutter-ctl"

case "$ACTION" in
  new)
    # Generate a unique cute name
    NAME=""
    for _ in $(seq 1 20); do
      CANDIDATE=$(/usr/local/bin/boxcutter-names generate)
      [ ! -d "/var/lib/boxcutter/vms/${CANDIDATE}" ] && { NAME="$CANDIDATE"; break; }
    done
    [ -z "$NAME" ] && { echo "Error: could not generate unique name"; exit 1; }
    $CTL create "$NAME" "${ARGS[@]:1}"
    $CTL start "$NAME"
    IP=$(jq -r '.ip' "/var/lib/boxcutter/vms/${NAME}/vm.json")
    echo ""
    echo "VM ready: ${NAME}"
    echo "Connect: ssh dev@${IP}"
    ;;
  list)    exec $CTL list ;;
  shell)
    [ -z "$TARGET" ] && { echo "Usage: ssh boxcutter shell <vm-name>"; exit 1; }
    exec $CTL shell "$TARGET"
    ;;
  start)
    [ -z "$TARGET" ] && { echo "Usage: ssh boxcutter start <vm-name>"; exit 1; }
    exec $CTL start "$TARGET"
    ;;
  stop)
    [ -z "$TARGET" ] && { echo "Usage: ssh boxcutter stop <vm-name>"; exit 1; }
    exec $CTL stop "$TARGET"
    ;;
  destroy)
    [ -z "$TARGET" ] && { echo "Usage: ssh boxcutter destroy <vm-name>"; exit 1; }
    exec $CTL destroy "$TARGET"
    ;;
  status)  exec $CTL status ;;
  proxy)
    # Direct TCP tunnel to a VM's SSH port — used as ProxyCommand
    [ -z "$TARGET" ] && { echo "Usage: ProxyCommand ssh boxcutter@host proxy <vm-name>" >&2; exit 1; }
    VM_DIR="/var/lib/boxcutter/vms"
    VM_NAME="${TARGET%.box}"
    [ -d "${VM_DIR}/${VM_NAME}" ] || { echo "VM '${VM_NAME}' does not exist." >&2; exit 1; }
    IP=$(jq -r '.ip' "${VM_DIR}/${VM_NAME}/vm.json")
    exec nc "$IP" 22
    ;;
  adduser)
    [ -z "$TARGET" ] && { echo "Usage: ssh boxcutter adduser <github-username>"; exit 1; }
    GH_USER="$TARGET"
    echo "Fetching SSH keys for github.com/${GH_USER}..."
    GH_KEYS=$(curl -sf "https://github.com/${GH_USER}.keys")
    if [ -z "$GH_KEYS" ]; then
      echo "Error: no keys found for '${GH_USER}' (check the username)"
      exit 1
    fi
    KEY_COUNT=$(echo "$GH_KEYS" | wc -l)
    # Add to boxcutter user's authorized_keys
    echo "$GH_KEYS" >> ~/.ssh/authorized_keys
    sort -u ~/.ssh/authorized_keys -o ~/.ssh/authorized_keys
    # Also update the trusted keys used when building golden images
    echo "$GH_KEYS" | sudo tee -a /etc/boxcutter/authorized_keys > /dev/null
    sudo sort -u /etc/boxcutter/authorized_keys -o /etc/boxcutter/authorized_keys 2>/dev/null || true
    echo "Added ${KEY_COUNT} key(s) for ${GH_USER}."
    echo "They can now: ssh boxcutter@<host> list"
    ;;
  help|*)
    cat << 'EOF'
Boxcutter SSH control interface

Commands:
  new                       Provision and start a new VM
  list                      List all VMs
  shell <name>              SSH into VM (use -t for interactive)
  start <name>              Start a stopped VM
  stop <name>               Stop a running VM
  destroy <name>            Tear down a VM
  status                    Host capacity summary
  adduser <github-user>     Add SSH keys from GitHub
  proxy <name>              TCP tunnel to VM (for ProxyCommand)

Usage: ssh boxcutter@<host> <command> [args]

SSH config for direct VM access (add to ~/.ssh/config):
  Host boxcutter
      HostName <host-ip>
      User boxcutter

  Host *.box
      User dev
      ProxyCommand ssh boxcutter proxy %n
EOF
    ;;
esac
