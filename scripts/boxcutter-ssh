#!/bin/bash
# Boxcutter SSH control interface — ForceCommand dispatch.
# Translates SSH commands to boxcutter-ctl calls.

read -r -a ARGS <<< "${SSH_ORIGINAL_COMMAND:-help}"
ACTION="${ARGS[0]}"
TARGET="${ARGS[1]}"

CTL="sudo /usr/local/bin/boxcutter-ctl"

case "$ACTION" in
  new)
    # Find next available agent-N name
    IDX=1
    while [ -d "/var/lib/boxcutter/vms/agent-${IDX}" ]; do
      IDX=$((IDX + 1))
    done
    NAME="agent-${IDX}"
    $CTL create "$NAME" "${ARGS[@]:1}"
    $CTL start "$NAME"
    echo ""
    echo "VM ready: ${NAME}"
    echo "Shell: ssh boxcutter shell ${NAME}"
    ;;
  list)    exec $CTL list ;;
  shell)
    [ -z "$TARGET" ] && { echo "Usage: ssh boxcutter shell <vm-name>"; exit 1; }
    exec $CTL shell "$TARGET"
    ;;
  start)
    [ -z "$TARGET" ] && { echo "Usage: ssh boxcutter start <vm-name>"; exit 1; }
    exec $CTL start "$TARGET"
    ;;
  stop)
    [ -z "$TARGET" ] && { echo "Usage: ssh boxcutter stop <vm-name>"; exit 1; }
    exec $CTL stop "$TARGET"
    ;;
  destroy)
    [ -z "$TARGET" ] && { echo "Usage: ssh boxcutter destroy <vm-name>"; exit 1; }
    exec $CTL destroy "$TARGET"
    ;;
  status)  exec $CTL status ;;
  help|*)
    cat << 'EOF'
Boxcutter SSH control interface

Commands:
  new              Provision and start a new VM
  list             List all VMs
  shell <name>     SSH into VM
  start <name>     Start a stopped VM
  stop <name>      Stop a running VM
  destroy <name>   Tear down a VM
  status           Host capacity summary

Usage: ssh boxcutter <command> [args]
EOF
    ;;
esac
