#!/bin/bash
# Set up the bridge network for Firecracker VMs.
# Bridges eth0 (LAN uplink) with VM TAP devices.
set -e

BRIDGE="brvm0"

case "${1:-up}" in
  up)
    # Ensure device nodes exist (may be missing in VMs without full udev)
    [ -e /dev/loop-control ] || mknod /dev/loop-control c 10 237
    for i in $(seq 0 7); do
      [ -b /dev/loop$i ] || mknod -m 660 /dev/loop$i b 7 $i
    done
    mkdir -p /dev/net
    [ -e /dev/net/tun ] || mknod /dev/net/tun c 10 200
    chmod 0666 /dev/net/tun
    [ -e /dev/kvm ] || mknod /dev/kvm c 10 232
    chmod 660 /dev/kvm
    chgrp kvm /dev/kvm 2>/dev/null || true

    # Find the primary network interface (the one with the default route)
    UPLINK=$(ip route | awk '/^default/{print $5; exit}')
    [ -z "$UPLINK" ] && { echo "Error: no default route found"; exit 1; }

    if ! ip link show "$BRIDGE" &>/dev/null; then
      echo "Creating bridge ${BRIDGE} with uplink ${UPLINK}..."

      # Capture current IP config before bridging
      CURRENT_IP=$(ip -4 addr show "$UPLINK" | awk '/inet /{print $2; exit}')
      CURRENT_GW=$(ip route | awk '/^default/{print $3; exit}')

      # Create bridge
      ip link add name "$BRIDGE" type bridge
      ip link set "$BRIDGE" up

      # Move uplink into bridge
      ip addr flush dev "$UPLINK"
      ip link set "$UPLINK" master "$BRIDGE"

      # Move IP to bridge
      ip addr add "$CURRENT_IP" dev "$BRIDGE"
      ip route add default via "$CURRENT_GW" dev "$BRIDGE" 2>/dev/null || true

      echo "Bridge ${BRIDGE} created (${CURRENT_IP})"
    else
      echo "Bridge ${BRIDGE} already exists."
    fi

    sysctl -w net.ipv4.ip_forward=1 >/dev/null
    echo "Network ready."
    ;;

  down)
    ip link del "$BRIDGE" 2>/dev/null || true
    echo "Bridge ${BRIDGE} removed."
    ;;
esac
