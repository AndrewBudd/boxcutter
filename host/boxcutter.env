# Boxcutter VM configuration
# Adjust these for your host's resources

# --- Physical host network ---
HOST_INTERFACE=enp34s0          # Physical NIC (for NAT masquerade)
HOST_BRIDGE_IP=192.168.50.1
HOST_BRIDGE_CIDR=24
BRIDGE_DEVICE=br-boxcutter
HOST_TAP_IP=192.168.50.1       # backwards compat
HOST_TAP_CIDR=24

# --- Orchestrator VM (small, long-lived) ---
ORCH_VCPU=2
ORCH_RAM=4G
ORCH_DISK=20G
ORCH_MAC=52:54:00:00:00:02
ORCH_IP=192.168.50.2
ORCH_TAP=tap-orch

# --- Node VM (beefy, ephemeral, multiple) ---
# IPs/MACs/TAPs derived from node number: boxcutter-node-N
#   IP:  192.168.50.(2+N)    e.g. node-1 → .3, node-2 → .4
#   MAC: 52:54:00:00:00:0(2+N)
#   TAP: tap-node{N}
NODE_VCPU=6
NODE_RAM=12G
NODE_DISK=150G
NODE_SUBNET=192.168.50          # first 3 octets
NODE_IP_OFFSET=2                # node-N gets .{offset+N}
