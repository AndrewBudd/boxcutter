# Boxcutter Node VM configuration
# Adjust these for your host's resources

NODE_VCPU=12
NODE_RAM=48G
NODE_DISK=150G
NODE_MAC=52:54:00:00:00:01

# Network — internal (not bridged to LAN)
# Host-to-Node link: point-to-point 192.168.50.0/30
HOST_INTERFACE=enp34s0          # Physical NIC (for NAT masquerade)
HOST_TAP_IP=192.168.50.1
NODE_IP=192.168.50.2
HOST_TAP_CIDR=30
TAP_DEVICE=tap-node0

# VMs use per-TAP point-to-point links (10.0.0.1/30 ↔ 10.0.0.2/30 inside Node VM)

# Tailscale — VMs join Tailscale for external access
# Auth key is stored at /etc/boxcutter/tailscale-authkey (never committed to git)
# Generate a reusable + ephemeral auth key at https://login.tailscale.com/admin/settings/keys
# Ephemeral keys auto-remove nodes when they disconnect (perfect for disposable VMs)
