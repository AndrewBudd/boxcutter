# Boxcutter Node VM configuration
# Adjust these for your host's resources

NODE_VCPU=12
NODE_RAM=48G
NODE_DISK=150G
NODE_MAC=52:54:00:00:00:01

# Network — bridged to LAN
HOST_INTERFACE=enp34s0
BRIDGE=br0
HOST_LAN_IP=192.168.2.124
NODE_IP=192.168.2.100
LAN_GW=192.168.2.1
LAN_CIDR=24
LAN_DNS="8.8.8.8"
TAP_DEVICE=tap-node0

# VM IP pool (assigned from this range)
VM_IP_START=200
VM_IP_END=250
VM_IP_PREFIX=192.168.2
