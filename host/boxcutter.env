# Boxcutter Node VM configuration
# Adjust these for your host's resources

NODE_VCPU=12
NODE_RAM=48G
NODE_DISK=150G
NODE_MAC=52:54:00:00:00:01
NODE_IP=10.0.100.2
NODE_CIDR=30

HOST_TAP_IP=10.0.100.1
TAP_DEVICE=tap-node0
HOST_INTERFACE=enp34s0
HOST_LAN_IP=192.168.2.124

# Ports forwarded from host to Node VM
DNAT_SSH=2222      # host:2222 → node:22
DNAT_HTTPS=443     # host:443  → node:443
DNAT_DNS=53        # host:53   → node:53 (UDP, for *.vm.lan)
