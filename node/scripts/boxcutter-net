#!/bin/bash
# Set up one-time network infrastructure for Firecracker VMs.
# Each VM gets its own TAP with point-to-point 10.0.0.1/30 ↔ 10.0.0.2/30.
# fwmark-based policy routing handles return traffic to the correct TAP.
set -e

case "${1:-up}" in
  up)
    # Ensure device nodes exist (may be missing in VMs without full udev)
    [ -e /dev/loop-control ] || mknod /dev/loop-control c 10 237
    for i in $(seq 0 7); do
      [ -b /dev/loop$i ] || mknod -m 660 /dev/loop$i b 7 $i
    done
    mkdir -p /dev/net
    [ -e /dev/net/tun ] || mknod /dev/net/tun c 10 200
    chmod 0666 /dev/net/tun
    [ -e /dev/kvm ] || mknod /dev/kvm c 10 232
    chmod 660 /dev/kvm
    chgrp kvm /dev/kvm 2>/dev/null || true

    # Enable IP forwarding
    sysctl -w net.ipv4.ip_forward=1 >/dev/null
    # Allow accepted TCP sockets to inherit the packet's fwmark (needed by vmid)
    sysctl -w net.ipv4.tcp_fwmark_accept=1 >/dev/null

    # Find uplink interface
    UPLINK=$(ip route | awk '/^default/{print $5; exit}')
    [ -z "$UPLINK" ] && { echo "Warning: no default route found, VMs won't have internet"; }

    if [ -n "$UPLINK" ]; then
      # Restore conntrack marks on return traffic (before per-TAP rules)
      iptables -t mangle -C PREROUTING -j CONNMARK --restore-mark 2>/dev/null || \
      iptables -t mangle -A PREROUTING -j CONNMARK --restore-mark

      # Save marks to conntrack after per-TAP marking
      iptables -t mangle -C POSTROUTING -m mark ! --mark 0 -j CONNMARK --save-mark 2>/dev/null || \
      iptables -t mangle -A POSTROUTING -m mark ! --mark 0 -j CONNMARK --save-mark

      # NAT all VM traffic (all VMs are 10.0.0.2)
      iptables -t nat -C POSTROUTING -s 10.0.0.2/32 -o "$UPLINK" -j MASQUERADE 2>/dev/null || \
      iptables -t nat -A POSTROUTING -s 10.0.0.2/32 -o "$UPLINK" -j MASQUERADE

      # Allow established return traffic
      iptables -C FORWARD -i "$UPLINK" -m state --state RELATED,ESTABLISHED -j ACCEPT 2>/dev/null || \
      iptables -A FORWARD -i "$UPLINK" -m state --state RELATED,ESTABLISHED -j ACCEPT
    fi

    echo "Network ready (per-TAP fwmark routing)."
    ;;

  down)
    UPLINK=$(ip route | awk '/^default/{print $5; exit}')
    if [ -n "$UPLINK" ]; then
      iptables -t mangle -D PREROUTING -j CONNMARK --restore-mark 2>/dev/null || true
      iptables -t mangle -D POSTROUTING -m mark ! --mark 0 -j CONNMARK --save-mark 2>/dev/null || true
      iptables -t nat -D POSTROUTING -s 10.0.0.2/32 -o "$UPLINK" -j MASQUERADE 2>/dev/null || true
      iptables -D FORWARD -i "$UPLINK" -m state --state RELATED,ESTABLISHED -j ACCEPT 2>/dev/null || true
    fi
    echo "Network rules removed."
    ;;
esac
