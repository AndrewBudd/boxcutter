#!/bin/bash
# boxcutter-ctl — Firecracker microVM lifecycle manager
set -eo pipefail

BOXCUTTER_HOME="/var/lib/boxcutter"
VM_DIR="${BOXCUTTER_HOME}/vms"
KERNEL="${BOXCUTTER_HOME}/kernel/vmlinux"
GOLDEN="${BOXCUTTER_HOME}/golden/rootfs.ext4"
SSH_KEY="/etc/boxcutter/secrets/cluster-ssh.key"
TS_AUTHKEY_FILE="/etc/boxcutter/secrets/tailscale-vm-authkey"
VMID_SOCKET="/run/vmid/admin.sock"

DEFAULT_VCPU=2
DEFAULT_RAM_MIB=2048
DEFAULT_DISK="50G"

usage() {
  cat <<EOF
boxcutter-ctl — Firecracker microVM manager

Commands:
  create <name> [--vcpu N] [--ram MiB] [--disk SIZE] [--clone REPO] [--mode normal|paranoid]
  start <name>
  stop <name>
  destroy <name>
  list
  shell <name>
  status
  golden build [SIZE]    Build golden rootfs image
  golden provision       Boot + provision golden image

Usage: boxcutter-ctl <command> [args]
EOF
}

# --- Mark allocation ---

allocate_mark() {
  local name=$1
  local mark
  mark=$(printf '%s' "$name" | cksum | awk '{print $1 % 65535 + 1}')

  # Check for collision against existing VMs
  local suffix=0
  while true; do
    local collision=false
    for d in "${VM_DIR}"/*/; do
      [ -f "${d}/vm.json" ] || continue
      local existing
      existing=$(jq -r '.mark // 0' "${d}/vm.json" 2>/dev/null) || continue
      if [ "$existing" = "$mark" ]; then
        collision=true
        break
      fi
    done
    $collision || break
    suffix=$((suffix + 1))
    mark=$(printf '%s_%d' "$name" "$suffix" | cksum | awk '{print $1 % 65535 + 1}')
  done

  echo "$mark"
}

# --- TAP device naming (max 15 chars) ---
tap_name() {
  local name=$1
  local tap="tap-${name}"
  if [ ${#tap} -le 15 ]; then
    echo "$tap"
  else
    local hash
    hash=$(echo -n "$name" | md5sum | cut -c1-4)
    echo "tap-${name:0:7}${hash}"
  fi
}

# --- SSH via TAP binding (all VMs are 10.0.0.2) ---
vm_ssh() {
  local tap=$1; shift
  ssh -o "ProxyCommand=socat - TCP:10.0.0.2:22,so-bindtodevice=${tap}" \
      -i "$SSH_KEY" -o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null \
      -o ConnectTimeout=5 -o BatchMode=yes "dev@10.0.0.2" "$@"
}

# --- Tailscale helpers ---

get_tailscale_ip() {
  local tap=$1
  local max_attempts=${2:-30}
  for i in $(seq 1 "$max_attempts"); do
    local ts_ip
    ts_ip=$(vm_ssh "$tap" "tailscale ip -4 2>/dev/null" 2>/dev/null) || true
    if [ -n "$ts_ip" ]; then
      echo "$ts_ip"
      return 0
    fi
    sleep 2
  done
  return 1
}

# --- vmid helpers ---

vmid_register() {
  local vm_id=$1 mark=$2 mode=$3 github_repo=${4:-}
  [ -S "$VMID_SOCKET" ] || return 0
  local payload
  payload=$(jq -n --arg id "$vm_id" --argjson mark "$mark" --arg mode "$mode" \
    --arg ip "10.0.0.2" --arg repo "$github_repo" \
    '{vm_id: $id, ip: $ip, mark: $mark, mode: $mode} + (if $repo != "" then {github_repo: $repo} else {} end)')
  curl -sf --unix-socket "$VMID_SOCKET" \
    -X POST http://localhost/internal/vms \
    -H 'Content-Type: application/json' \
    -d "$payload" >/dev/null 2>&1 || true
}

vmid_deregister() {
  local vm_id=$1
  [ -S "$VMID_SOCKET" ] || return 0
  curl -sf --unix-socket "$VMID_SOCKET" \
    -X DELETE "http://localhost/internal/vms/${vm_id}" >/dev/null 2>&1 || true
}

# Parse a git clone URL (SSH or HTTPS) into owner/repo format
parse_repo_url() {
  local url=$1
  # SSH: git@github.com:owner/repo.git
  if [[ "$url" =~ ^git@[^:]+:(.+)$ ]]; then
    echo "${BASH_REMATCH[1]}" | sed 's/\.git$//'
    return
  fi
  # HTTPS: https://github.com/owner/repo.git
  if [[ "$url" =~ ^https?://[^/]+/(.+)$ ]]; then
    echo "${BASH_REMATCH[1]}" | sed 's/\.git$//'
    return
  fi
  # Bare hostname: github.com/owner/repo
  if [[ "$url" =~ ^[^/]+\.[^/]+/(.+)$ ]]; then
    echo "${BASH_REMATCH[1]}" | sed 's/\.git$//'
    return
  fi
  # Already owner/repo format
  echo "$url"
}

# --- Per-TAP network setup/teardown ---

setup_vm_tap() {
  local tap=$1 mark=$2

  local uplink uplink_gw
  uplink=$(ip route | awk '/^default/{print $5; exit}')
  uplink_gw=$(ip route | awk '/^default/{print $3; exit}')

  # Create TAP with point-to-point addressing
  ip tuntap add dev "$tap" mode tap
  ip addr add 10.0.0.1 peer 10.0.0.2 dev "$tap"
  ip link set "$tap" up

  # Mark packets from this TAP
  iptables -t mangle -I PREROUTING 2 -i "$tap" -j MARK --set-mark "$mark"

  # Policy routing: return traffic goes back to correct TAP
  # Priority must be below 32766 (main table lookup) to take precedence
  local prio=$((10000 + (mark % 20000)))
  ip rule add fwmark "$mark" lookup "$mark" priority "$prio"
  ip route add 10.0.0.2 dev "$tap" table "$mark"
  if [ -n "$uplink_gw" ] && [ -n "$uplink" ]; then
    ip route add default via "$uplink_gw" dev "$uplink" table "$mark"
  fi

  # Allow forwarding from this TAP
  iptables -I FORWARD -i "$tap" -j ACCEPT
}

teardown_vm_tap() {
  local tap=$1 mark=$2

  iptables -t mangle -D PREROUTING -i "$tap" -j MARK --set-mark "$mark" 2>/dev/null || true
  iptables -D FORWARD -i "$tap" -j ACCEPT 2>/dev/null || true
  # Paranoid mode rules
  iptables -D FORWARD -i "$tap" ! -d 10.0.0.0/24 -j DROP 2>/dev/null || true
  iptables -D FORWARD -i "$tap" -d 10.0.0.1/32 -p tcp --dport 8080 -j ACCEPT 2>/dev/null || true

  ip rule del fwmark "$mark" lookup "$mark" 2>/dev/null || true
  ip route flush table "$mark" 2>/dev/null || true
  ip link del "$tap" 2>/dev/null || true
}

# --- Commands ---

cmd_create() {
  local name=$1; shift
  local vcpu=$DEFAULT_VCPU ram=$DEFAULT_RAM_MIB disk=$DEFAULT_DISK clone_url="" mode="normal"

  while [ $# -gt 0 ]; do
    case "$1" in
      --vcpu)  vcpu=$2; shift 2 ;;
      --ram)   ram=$2; shift 2 ;;
      --disk)  disk=$2; shift 2 ;;
      --clone) clone_url=$2; shift 2 ;;
      --mode)  mode=$2; shift 2 ;;
      *) echo "Unknown option: $1"; exit 1 ;;
    esac
  done

  [ -z "$name" ] && { echo "Usage: boxcutter-ctl create <name> [options]"; exit 1; }
  [ -d "${VM_DIR}/${name}" ] && { echo "VM '${name}' already exists."; exit 1; }
  [ -f "$GOLDEN" ] || { echo "Golden image not found. Run: boxcutter-ctl golden build"; exit 1; }

  echo "Creating VM: ${name} (${vcpu} vCPU, $((ram / 1024))GB RAM, ${disk} disk, mode: ${mode})"

  mkdir -p "${VM_DIR}/${name}"

  local mark tap
  mark=$(allocate_mark "$name")
  tap=$(tap_name "$name")

  # Fixed MAC — no shared L2, so no conflict
  local mac="AA:FC:00:00:00:01"

  # Create COW snapshot of golden image
  echo "  Creating copy-on-write snapshot..."
  local golden_size
  golden_size=$(stat -L -c%s "$GOLDEN")
  local disk_bytes
  disk_bytes=$(numfmt --from=iec "$disk" 2>/dev/null || echo "$golden_size")
  [ "$disk_bytes" -lt "$golden_size" ] && disk_bytes=$golden_size

  # Create sparse COW overlay file (only stores changes)
  truncate -s "$disk_bytes" "${VM_DIR}/${name}/cow.img"

  # Create dm-snapshot: golden (read-only base) + cow (writable overlay)
  local base_loop cow_loop dm_name
  dm_name="bc-${name}"
  base_loop=$(losetup --find --show --read-only "$GOLDEN")
  cow_loop=$(losetup --find --show "${VM_DIR}/${name}/cow.img")
  local sectors=$(( golden_size / 512 ))

  echo "0 ${sectors} snapshot ${base_loop} ${cow_loop} P 8" | dmsetup create "$dm_name"

  jq -n --arg base "$base_loop" --arg cow "$cow_loop" --arg dm "$dm_name" \
    '{"base_loop": $base, "cow_loop": $cow, "dm_name": $dm}' > "${VM_DIR}/${name}/snapshot.json"

  # If disk is larger than golden, resize the filesystem
  if [ "$disk_bytes" -gt "$golden_size" ]; then
    e2fsck -f -y "/dev/mapper/${dm_name}" >/dev/null 2>&1 || true
    resize2fs "/dev/mapper/${dm_name}" >/dev/null 2>&1 || true
  fi

  # Kernel ip= parameter: all VMs are 10.0.0.2 with gateway 10.0.0.1
  local boot_ip="ip=10.0.0.2::10.0.0.1:255.255.255.252:${name}:eth0:off:8.8.8.8"

  # Parse clone URL to owner/repo if provided
  local github_repo=""
  if [ -n "$clone_url" ]; then
    github_repo=$(parse_repo_url "$clone_url")
  fi

  # VM metadata
  local vm_json
  vm_json=$(jq -n \
    --arg name "$name" \
    --argjson vcpu "$vcpu" \
    --argjson ram "$ram" \
    --argjson mark "$mark" \
    --arg mode "$mode" \
    --arg mac "$mac" \
    --arg disk "$disk" \
    --arg tap "$tap" \
    --arg created "$(date -Iseconds)" \
    --arg clone_url "$clone_url" \
    --arg github_repo "$github_repo" \
    '{name: $name, vcpu: $vcpu, ram_mib: $ram, mark: $mark, mode: $mode, mac: $mac, disk: $disk, tap: $tap, created: $created} +
     (if $clone_url != "" then {clone_url: $clone_url, github_repo: $github_repo} else {} end)')
  echo "$vm_json" > "${VM_DIR}/${name}/vm.json"

  # Firecracker config
  cat > "${VM_DIR}/${name}/fc-config.json" <<EOF
{
  "boot-source": {
    "kernel_image_path": "${KERNEL}",
    "boot_args": "console=ttyS0 reboot=k panic=1 pci=off random.trust_cpu=on root=/dev/vda rw init=/sbin/init ${boot_ip}"
  },
  "drives": [
    {
      "drive_id": "rootfs",
      "path_on_host": "/dev/mapper/bc-${name}",
      "is_root_device": true,
      "is_read_only": false
    }
  ],
  "network-interfaces": [
    {
      "iface_id": "eth0",
      "guest_mac": "${mac}",
      "host_dev_name": "${tap}"
    }
  ],
  "machine-config": {
    "vcpu_count": ${vcpu},
    "mem_size_mib": ${ram}
  },
  "entropy": {
    "rate_limiter": {
      "bandwidth": {
        "size": 1048576,
        "refill_time": 1000
      }
    }
  }
}
EOF

  # Inject CA cert into rootfs for internal TLS
  if [ -f /etc/boxcutter/secrets/ca.crt ]; then
    echo "  Injecting CA cert..."
    MOUNT_DIR=$(mktemp -d)
    mount "/dev/mapper/bc-${name}" "$MOUNT_DIR"
    mkdir -p "${MOUNT_DIR}/usr/local/share/ca-certificates"
    cp /etc/boxcutter/secrets/ca.crt "${MOUNT_DIR}/usr/local/share/ca-certificates/boxcutter-ca.crt"
    chroot "$MOUNT_DIR" update-ca-certificates 2>/dev/null || true
    umount "$MOUNT_DIR"
    rmdir "$MOUNT_DIR"
  fi

  # Inject SSH keys (golden image has no keys baked in — all injected here)
  echo "  Injecting SSH keys..."
  MOUNT_DIR=$(mktemp -d)
  mount "/dev/mapper/bc-${name}" "$MOUNT_DIR"
  mkdir -p "${MOUNT_DIR}/home/dev/.ssh"
  : > "${MOUNT_DIR}/home/dev/.ssh/authorized_keys"

  # Cluster SSH key (for node→VM access via boxcutter-ctl shell)
  if [ -f /etc/boxcutter/secrets/cluster-ssh.key.pub ]; then
    cat /etc/boxcutter/secrets/cluster-ssh.key.pub >> "${MOUNT_DIR}/home/dev/.ssh/authorized_keys"
  fi

  # User-provided trusted keys
  if [ -f /etc/boxcutter/secrets/authorized-keys ]; then
    cat /etc/boxcutter/secrets/authorized-keys >> "${MOUNT_DIR}/home/dev/.ssh/authorized_keys"
  fi

  chown -R 1000:1000 "${MOUNT_DIR}/home/dev/.ssh"
  chmod 700 "${MOUNT_DIR}/home/dev/.ssh"
  chmod 600 "${MOUNT_DIR}/home/dev/.ssh/authorized_keys"
  umount "$MOUNT_DIR"
  rmdir "$MOUNT_DIR"

  echo "  VM created: ${name} (mark: ${mark}, mode: ${mode})"
  echo "  Start with: boxcutter-ctl start ${name}"
}

cmd_start() {
  local name=$1
  [ -z "$name" ] && { echo "Usage: boxcutter-ctl start <name>"; exit 1; }
  [ -d "${VM_DIR}/${name}" ] || { echo "VM '${name}' does not exist."; exit 1; }

  if [ -f "${VM_DIR}/${name}/firecracker.pid" ]; then
    local pid
    pid=$(cat "${VM_DIR}/${name}/firecracker.pid")
    kill -0 "$pid" 2>/dev/null && { echo "VM '${name}' is already running (PID ${pid})."; exit 1; }
  fi

  local mark mac tap mode
  mark=$(jq -r '.mark' "${VM_DIR}/${name}/vm.json")
  mac=$(jq -r '.mac' "${VM_DIR}/${name}/vm.json")
  tap=$(jq -r '.tap // empty' "${VM_DIR}/${name}/vm.json")
  mode=$(jq -r '.mode // "normal"' "${VM_DIR}/${name}/vm.json")
  [ -z "$tap" ] && tap=$(tap_name "$name")

  echo "Starting VM: ${name} (mark: ${mark}, mode: ${mode})"

  # Ensure dm-snapshot is active
  local dm_name="bc-${name}"
  if [ ! -e "/dev/mapper/${dm_name}" ]; then
    if [ -f "${VM_DIR}/${name}/cow.img" ]; then
      local base_size base_loop cow_loop sectors
      base_size=$(stat -c%s "$GOLDEN")
      base_loop=$(losetup --find --show --read-only "$GOLDEN")
      cow_loop=$(losetup --find --show "${VM_DIR}/${name}/cow.img")
      sectors=$(( base_size / 512 ))
      echo "0 ${sectors} snapshot ${base_loop} ${cow_loop} P 8" | dmsetup create "$dm_name"
      jq -n --arg base "$base_loop" --arg cow "$cow_loop" --arg dm "$dm_name" \
        '{"base_loop": $base, "cow_loop": $cow, "dm_name": $dm}' > "${VM_DIR}/${name}/snapshot.json"
    fi
  fi

  # Set up per-TAP networking with fwmark
  if ! ip link show "$tap" &>/dev/null; then
    setup_vm_tap "$tap" "$mark"
  fi

  # Paranoid mode: block direct internet, allow only proxy
  if [ "$mode" = "paranoid" ]; then
    iptables -I FORWARD -i "$tap" -d 10.0.0.1/32 -p tcp --dport 8080 -j ACCEPT
    iptables -I FORWARD -i "$tap" ! -d 10.0.0.0/24 -j DROP
  fi

  # Clean stale socket
  rm -f "${VM_DIR}/${name}/api.sock"

  # Launch Firecracker
  firecracker \
    --api-sock "${VM_DIR}/${name}/api.sock" \
    --config-file "${VM_DIR}/${name}/fc-config.json" \
    > "${VM_DIR}/${name}/firecracker.log" 2>&1 &

  echo $! > "${VM_DIR}/${name}/firecracker.pid"

  echo "  VM started (PID $(cat "${VM_DIR}/${name}/firecracker.pid"))"

  # Join Tailscale (skip for internal provision VMs starting with _)
  if [[ "$name" != _* ]]; then
    # Wait for SSH to be ready
    echo "  Waiting for VM to boot..."
    for i in $(seq 1 30); do
      vm_ssh "$tap" echo ready 2>/dev/null && break
      sleep 1
    done

    # Provision Tailscale from Node VM — key never stored on VM disk
    local ts_authkey=""
    if [ -f "$TS_AUTHKEY_FILE" ]; then
      ts_authkey=$(cat "$TS_AUTHKEY_FILE")
    fi
    if [ -n "$ts_authkey" ]; then
      echo "  Joining Tailscale..."
      vm_ssh "$tap" \
        "sudo tailscale up --authkey='${ts_authkey}' --hostname='${name}'" 2>/dev/null || true

      # Expose SSH via Tailscale TCP proxy
      vm_ssh "$tap" \
        "sudo tailscale serve --bg --tcp 22 tcp://localhost:22" 2>/dev/null || true

      local ts_ip
      ts_ip=$(get_tailscale_ip "$tap" 15) || true
      if [ -n "$ts_ip" ]; then
        local tmp_json
        tmp_json=$(jq --arg tsip "$ts_ip" '. + {"tailscale_ip": $tsip}' "${VM_DIR}/${name}/vm.json")
        echo "$tmp_json" > "${VM_DIR}/${name}/vm.json"
        echo "  Tailscale IP: ${ts_ip}"
        echo "  SSH: ssh ${ts_ip}"
      else
        echo "  Warning: Tailscale did not come up."
      fi
    else
      echo "  Warning: No Tailscale auth key at ${TS_AUTHKEY_FILE}"
    fi

    # Register with vmid
    local github_repo
    github_repo=$(jq -r '.github_repo // ""' "${VM_DIR}/${name}/vm.json")
    vmid_register "$name" "$mark" "$mode" "$github_repo"

    # Paranoid mode: set proxy env vars inside VM
    if [ "$mode" = "paranoid" ]; then
      echo "  Configuring proxy environment..."
      vm_ssh "$tap" "sudo bash -c 'cat > /etc/profile.d/boxcutter-proxy.sh << \"PROXYEOF\"
export HTTP_PROXY=http://10.0.0.1:8080
export HTTPS_PROXY=http://10.0.0.1:8080
export http_proxy=http://10.0.0.1:8080
export https_proxy=http://10.0.0.1:8080
export NO_PROXY=10.0.0.1,localhost,127.0.0.1
export no_proxy=10.0.0.1,localhost,127.0.0.1
PROXYEOF'" 2>/dev/null || true
    fi

    # Clone repo if --clone was specified
    local clone_url
    clone_url=$(jq -r '.clone_url // ""' "${VM_DIR}/${name}/vm.json")
    if [ -n "$clone_url" ]; then
      echo "  Cloning ${clone_url}..."

      # Mint a GitHub token from vmid (Node-side, via admin socket)
      local gh_token="" token_error=""
      if [ -S "$VMID_SOCKET" ] && [ -n "$github_repo" ]; then
        local token_resp
        token_resp=$(curl -s --unix-socket "$VMID_SOCKET" \
          -X POST "http://localhost/internal/vms/${name}/github-token" 2>/dev/null)
        gh_token=$(echo "$token_resp" | jq -r '.token // empty' 2>/dev/null) || true
        if [ -z "$gh_token" ]; then
          token_error=$(echo "$token_resp" | head -1)
        fi
      elif [ ! -S "$VMID_SOCKET" ]; then
        token_error="vmid not running (no socket at $VMID_SOCKET)"
      elif [ -z "$github_repo" ]; then
        token_error="no github_repo parsed from clone URL"
      fi

      if [ -n "$token_error" ]; then
        echo "  Token error: ${token_error}"
        echo "  Attempting clone without auth (will only work for public repos)..."
      fi

      # Build the clone URL with token auth for HTTPS
      local auth_clone_url="$clone_url"
      if [ -n "$gh_token" ]; then
        local repo_path="$github_repo"
        auth_clone_url="https://x-access-token:${gh_token}@github.com/${repo_path}.git"
      fi

      local clone_output
      clone_output=$(vm_ssh "$tap" \
        "git clone '${auth_clone_url}' ~/project 2>&1")
      local clone_rc=$?

      if [ $clone_rc -eq 0 ]; then
        echo "  Cloned successfully."
        if [ -n "$gh_token" ]; then
          # Strip token from remote URL + set up gh CLI auth + git credential helper
          vm_ssh "$tap" \
            "cd ~/project && git remote set-url origin 'https://github.com/${github_repo}.git'
             mkdir -p ~/.config/gh
             cat > ~/.config/gh/hosts.yml <<GHEOF
github.com:
    oauth_token: ${gh_token}
    user: x-access-token
    git_protocol: https
GHEOF
             git config --global credential.helper '!f() { echo username=x-access-token; echo password=${gh_token}; }; f'" 2>/dev/null || true
        fi
      else
        echo "  Clone failed."
        echo "$clone_output" | sed "s|x-access-token:[^@]*@|x-access-token:***@|g" | sed 's/^/    /'
        if [ -n "$gh_token" ]; then
          echo "  The GitHub App token was minted but the repo may not be accessible."
          echo "  Check: https://github.com/organizations/${github_repo%%/*}/settings/installations"
          echo "  Ensure the boxcutter-gh app has access to the '${github_repo##*/}' repository."
        fi
      fi
    fi
  else
    echo "  Internal VM — skipping Tailscale"
  fi
}

cmd_stop() {
  local name=$1
  [ -z "$name" ] && { echo "Usage: boxcutter-ctl stop <name>"; exit 1; }
  [ -f "${VM_DIR}/${name}/firecracker.pid" ] || { echo "VM '${name}' is not running."; return 0; }

  local pid
  pid=$(cat "${VM_DIR}/${name}/firecracker.pid")

  echo "Stopping VM: ${name}"

  # Graceful shutdown via Firecracker API
  if [ -S "${VM_DIR}/${name}/api.sock" ]; then
    curl -s --unix-socket "${VM_DIR}/${name}/api.sock" \
      -X PUT http://localhost/actions \
      -H 'Content-Type: application/json' \
      -d '{"action_type":"SendCtrlAltDel"}' 2>/dev/null || true

    for _ in $(seq 1 10); do
      kill -0 "$pid" 2>/dev/null || break
      sleep 1
    done
  fi

  # Force kill if still running
  if kill -0 "$pid" 2>/dev/null; then
    kill -9 "$pid" 2>/dev/null || true
  fi

  # Cleanup TAP + fwmark routing
  local tap mark
  tap=$(jq -r '.tap // empty' "${VM_DIR}/${name}/vm.json" 2>/dev/null)
  mark=$(jq -r '.mark // 0' "${VM_DIR}/${name}/vm.json" 2>/dev/null)
  [ -z "$tap" ] && tap=$(tap_name "$name")

  rm -f "${VM_DIR}/${name}/firecracker.pid" "${VM_DIR}/${name}/api.sock"

  if [ "$mark" != "0" ] && [ -n "$mark" ]; then
    teardown_vm_tap "$tap" "$mark"
  else
    ip link del "$tap" 2>/dev/null || true
  fi

  # Tear down dm-snapshot
  local dm_name="bc-${name}"
  if [ -e "/dev/mapper/${dm_name}" ]; then
    for _ in $(seq 1 5); do
      dmsetup remove "$dm_name" 2>/dev/null && break
      sleep 1
    done
  fi
  if [ -f "${VM_DIR}/${name}/snapshot.json" ]; then
    local base_loop cow_loop
    base_loop=$(jq -r '.base_loop' "${VM_DIR}/${name}/snapshot.json")
    cow_loop=$(jq -r '.cow_loop' "${VM_DIR}/${name}/snapshot.json")
    losetup -d "$cow_loop" 2>/dev/null || true
    losetup -d "$base_loop" 2>/dev/null || true
    rm -f "${VM_DIR}/${name}/snapshot.json"
  fi

  echo "  Stopped."
}

cmd_destroy() {
  local name=$1
  [ -z "$name" ] && { echo "Usage: boxcutter-ctl destroy <name>"; exit 1; }
  [ -d "${VM_DIR}/${name}" ] || { echo "VM '${name}' does not exist."; exit 1; }

  # Deregister from vmid (purges sentinels)
  vmid_deregister "$name"

  # Stop if running (ephemeral Tailscale key auto-removes disconnected nodes)
  if [ -f "${VM_DIR}/${name}/firecracker.pid" ]; then
    local pid
    pid=$(cat "${VM_DIR}/${name}/firecracker.pid")
    kill -0 "$pid" 2>/dev/null && cmd_stop "$name"
  fi

  # Clean up any remaining dm-snapshot and loop devices
  local dm_name="bc-${name}"
  if [ -e "/dev/mapper/${dm_name}" ]; then
    dmsetup remove "$dm_name" 2>/dev/null || true
  fi
  if [ -f "${VM_DIR}/${name}/snapshot.json" ]; then
    local base_loop cow_loop
    base_loop=$(jq -r '.base_loop' "${VM_DIR}/${name}/snapshot.json")
    cow_loop=$(jq -r '.cow_loop' "${VM_DIR}/${name}/snapshot.json")
    losetup -d "$base_loop" 2>/dev/null || true
    losetup -d "$cow_loop" 2>/dev/null || true
  fi

  rm -rf "${VM_DIR:?}/${name}"
  echo "VM '${name}' destroyed."
}

cmd_list() {
  printf "%-20s %-18s %-8s %-8s %-10s %-10s %-8s\n" "NAME" "TAILSCALE IP" "MARK" "MODE" "VCPU" "RAM" "STATUS"
  for d in "${VM_DIR}"/*/; do
    [ -f "${d}/vm.json" ] || continue
    local name ts_ip mark mode vcpu ram status
    name=$(basename "$d")
    ts_ip=$(jq -r '.tailscale_ip // "-"' "${d}/vm.json")
    mark=$(jq -r '.mark // "-"' "${d}/vm.json")
    mode=$(jq -r '.mode // "normal"' "${d}/vm.json")
    vcpu=$(jq -r '.vcpu' "${d}/vm.json")
    ram=$(jq -r '.ram_mib' "${d}/vm.json")
    status="stopped"
    if [ -f "${d}/firecracker.pid" ]; then
      local pid
      pid=$(cat "${d}/firecracker.pid")
      kill -0 "$pid" 2>/dev/null && status="running"
    fi
    printf "%-20s %-18s %-8s %-8s %-10s %-10s %-8s\n" "$name" "$ts_ip" "$mark" "$mode" "$vcpu" "$((ram/1024))GB" "$status"
  done
}

cmd_shell() {
  local name=$1
  [ -z "$name" ] && { echo "Usage: boxcutter-ctl shell <name>"; exit 1; }
  [ -d "${VM_DIR}/${name}" ] || { echo "VM '${name}' does not exist."; exit 1; }

  local tap
  tap=$(jq -r '.tap // empty' "${VM_DIR}/${name}/vm.json")
  [ -z "$tap" ] && tap=$(tap_name "$name")
  exec ssh -t -o "ProxyCommand=socat - TCP:10.0.0.2:22,so-bindtodevice=${tap}" \
    -i "$SSH_KEY" -o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null "dev@10.0.0.2"
}

cmd_status() {
  local total_ram used_ram=0 vm_count=0 running=0
  total_ram=$(free -g | awk '/^Mem:/{print $2}')

  for d in "${VM_DIR}"/*/; do
    [ -f "${d}/vm.json" ] || continue
    vm_count=$((vm_count + 1))
    if [ -f "${d}/firecracker.pid" ]; then
      local pid
      pid=$(cat "${d}/firecracker.pid")
      if kill -0 "$pid" 2>/dev/null; then
        running=$((running + 1))
        local ram
        ram=$(jq -r '.ram_mib' "${d}/vm.json")
        used_ram=$((used_ram + ram / 1024))
      fi
    fi
  done

  # Show Tailscale status
  local ts_ip=""
  if command -v tailscale &>/dev/null; then
    ts_ip=$(tailscale ip -4 2>/dev/null) || true
  fi

  echo "Host: $(hostname)"
  [ -n "$ts_ip" ] && echo "Tailscale: ${ts_ip}"
  echo "VMs: ${running} running / ${vm_count} total"
  echo "RAM: ${used_ram}GB allocated / ${total_ram}GB total"
  echo "Headroom: $((total_ram - used_ram))GB"
}

# --- Main ---

case "${1:-help}" in
  create|new)  shift; cmd_create "$@" ;;
  start)   cmd_start "$2" ;;
  stop)    cmd_stop "$2" ;;
  destroy) cmd_destroy "$2" ;;
  list)    cmd_list ;;
  shell)   cmd_shell "$2" ;;
  status)  cmd_status ;;
  golden)
    case "$2" in
      build) exec "${BOXCUTTER_HOME}/golden/build.sh" "${3:-}" ;;
      provision)
        echo "=== Provisioning golden image (Phase 2) ==="
        GOLDEN="${BOXCUTTER_HOME}/golden/rootfs.ext4"
        [ -f "$GOLDEN" ] || { echo "No golden base image. Run: boxcutter-ctl golden build"; exit 1; }

        cmd_create _gprov --vcpu 8 --ram 16384
        cmd_start _gprov

        PROV_TAP=$(jq -r '.tap // empty' "${VM_DIR}/_gprov/vm.json")
        [ -z "$PROV_TAP" ] && PROV_TAP=$(tap_name "_gprov")
        echo "Waiting for VM to boot..."
        for i in $(seq 1 60); do
          vm_ssh "$PROV_TAP" echo ready 2>/dev/null && break
          sleep 2
        done

        echo "Running provision script inside VM..."
        PROV_SCRIPT="${BOXCUTTER_HOME}/golden/provision.sh"
        [ -f "$PROV_SCRIPT" ] || PROV_SCRIPT="/mnt/boxcutter/golden/provision.sh"
        vm_ssh "$PROV_TAP" "sudo bash -s" < "$PROV_SCRIPT"

        echo "Shutting down provision VM..."
        dm_name="bc-_gprov"
        if [ -e "/dev/mapper/${dm_name}" ]; then
          echo "Merging snapshot into golden image..."
          dd if="/dev/mapper/${dm_name}" of="${GOLDEN}.new" bs=4M status=progress
          cmd_stop _gprov
          mv "${GOLDEN}.new" "$GOLDEN"
        else
          cmd_stop _gprov
        fi
        cmd_destroy _gprov

        echo ""
        echo "=== Golden image provisioned ==="
        echo "Path: ${GOLDEN}"
        du -h "$GOLDEN"
        ;;
      *) echo "Usage: boxcutter-ctl golden {build|provision}" ;;
    esac
    ;;
  help|*) usage ;;
esac
