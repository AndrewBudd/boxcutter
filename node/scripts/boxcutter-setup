#!/bin/bash
# boxcutter-setup — Bootstrap bundle validation and secret generation.
# Reads /etc/boxcutter/boxcutter.yaml and ensures all secrets are present.
# Idempotent — safe to run multiple times.
set -eo pipefail

CONF_DIR="/etc/boxcutter"
SECRETS_DIR="${CONF_DIR}/secrets"
CONFIG="${CONF_DIR}/boxcutter.yaml"

# --- Helpers ---

die() { echo "Error: $1" >&2; exit 1; }

yaml_val() {
  # Simple yaml value extractor (single-level or dotted keys).
  # Works for our flat config; not a full YAML parser.
  local key=$1 file=${2:-$CONFIG}
  grep -E "^\s*${key}:" "$file" | head -1 | sed 's/^[^:]*:\s*//' | sed 's/\s*#.*//' | sed 's/^\s*"\(.*\)"\s*$/\1/'
}

# --- Validate bundle ---

echo "=== boxcutter-setup ==="

[ -f "$CONFIG" ] || die "Config not found: ${CONFIG}"
echo "Config: ${CONFIG}"

mkdir -p "$SECRETS_DIR"

# Required secrets (must exist in bundle)
REQUIRED_SECRETS=(
  "tailscale-vm-authkey"
  "tailscale-node-authkey"
  "authorized-keys"
)

# Check if GitHub is enabled
GITHUB_ENABLED=$(yaml_val "enabled" "$CONFIG" | head -1)
if [ "$GITHUB_ENABLED" = "true" ]; then
  REQUIRED_SECRETS+=("github-app.pem")
fi

MISSING=()
for secret in "${REQUIRED_SECRETS[@]}"; do
  if [ ! -f "${SECRETS_DIR}/${secret}" ] || [ ! -s "${SECRETS_DIR}/${secret}" ]; then
    MISSING+=("$secret")
  fi
done

if [ ${#MISSING[@]} -gt 0 ]; then
  echo "Missing required secrets:"
  for m in "${MISSING[@]}"; do
    echo "  - ${SECRETS_DIR}/${m}"
  done
  die "Place missing secrets in ${SECRETS_DIR}/ and re-run."
fi

echo "All required secrets present."

# --- Auto-generate secrets that can be generated ---

# Cluster SSH key (shared across all nodes, used for node→VM access)
if [ -f "${SECRETS_DIR}/cluster-ssh.key" ]; then
  echo "Cluster SSH key: exists"
else
  echo "Warning: cluster-ssh.key not found — node→VM SSH will not work"
fi

# CA + leaf certs (delegate to boxcutter-tls)
if [ ! -f "${SECRETS_DIR}/ca.crt" ] || [ ! -f "${SECRETS_DIR}/ca.key" ]; then
  echo "Generating TLS certificates..."
  /usr/local/bin/boxcutter-tls
else
  echo "TLS certificates: exist"
fi

# JWT signing key — vmid auto-generates if absent, but create placeholder note
if [ ! -f "${SECRETS_DIR}/jwt-signing.pem" ]; then
  echo "JWT signing key: will be auto-generated by vmid on first start"
fi

# --- Join Tailscale ---

if command -v tailscale &>/dev/null; then
  if ! tailscale status &>/dev/null; then
    HOSTNAME=$(yaml_val "hostname" "$CONFIG")
    [ -z "$HOSTNAME" ] && HOSTNAME="boxcutter"
    NODE_KEY=$(cat "${SECRETS_DIR}/tailscale-node-authkey" | tr -d '[:space:]')
    echo "Joining Tailscale as '${HOSTNAME}'..."
    tailscale up --authkey="$NODE_KEY" --hostname="$HOSTNAME"
    echo "  Tailscale connected."
  else
    echo "Tailscale: already connected"
  fi
else
  echo "Tailscale: not installed (skipping)"
fi

# --- Generate vmid config ---

echo "Generating vmid config..."
mkdir -p /etc/vmid /run/vmid

VMID_CONFIG="/etc/vmid/config.yaml"

# Start with base config
cat > "$VMID_CONFIG" <<'EOF'
listen:
  vm_port: 80
  admin_socket: /run/vmid/admin.sock

jwt:
  ttl: "10m"

log:
  level: info
  format: json
EOF

# Append GitHub App config if enabled
if [ "$GITHUB_ENABLED" = "true" ]; then
  APP_ID=$(yaml_val "app_id" "$CONFIG")
  # Extract first installation ID (vmid uses a single default installation_id)
  INSTALL_ID=$(awk '/installation_ids:/,/^[^ ]/' "$CONFIG" | grep -E '^\s*-\s' | head -1 | sed 's/.*-\s*//')

  if [ -n "$APP_ID" ] && [ -f "${SECRETS_DIR}/github-app.pem" ]; then
    cat >> "$VMID_CONFIG" <<EOF

github:
  app_id: ${APP_ID}
  private_key_path: ${SECRETS_DIR}/github-app.pem
  installation_id: ${INSTALL_ID}
EOF
    echo "  vmid config: GitHub App enabled (app_id: ${APP_ID})"
  fi
else
  echo "  vmid config: GitHub App disabled"
fi

# --- Populate boxcutter user SSH keys ---

if id boxcutter &>/dev/null; then
  echo "Syncing authorized keys to boxcutter user..."
  mkdir -p /home/boxcutter/.ssh
  cp "${SECRETS_DIR}/authorized-keys" /home/boxcutter/.ssh/authorized_keys
  chown -R boxcutter:boxcutter /home/boxcutter/.ssh
  chmod 700 /home/boxcutter/.ssh
  chmod 600 /home/boxcutter/.ssh/authorized_keys
fi

# --- Summary ---

echo ""
echo "=== Setup complete ==="
echo "  Config:       ${CONFIG}"
echo "  Secrets:      ${SECRETS_DIR}/"
echo "  SSH key:      ${SECRETS_DIR}/cluster-ssh.key"
echo "  CA cert:      ${SECRETS_DIR}/ca.crt"
echo "  vmid config:  ${VMID_CONFIG}"
TS_IP=$(tailscale ip -4 2>/dev/null) || true
[ -n "$TS_IP" ] && echo "  Tailscale IP: ${TS_IP}"
