[Unit]
Description=VM Identity & Token Broker
After=network.target

[Service]
Type=simple
ExecStartPre=/bin/mkdir -p /run/vmid
ExecStart=/usr/local/bin/vmid -config /etc/vmid/config.yaml
Restart=always
RestartSec=5

# Socket should be readable by boxcutter group
RuntimeDirectory=vmid
RuntimeDirectoryMode=0755

[Install]
WantedBy=multi-user.target
